<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ shop.name }}</title>
    <link href="https://fonts.googleapis.com/css2?family=Marcellus&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
    {{ content_for_header }}
    <style>
      body { margin:0; min-height:100vh; display:flex; align-items:center; justify-content:center; background:#f7f3ec; color:#1a1611; font-family:'Jost',sans-serif; text-align:center; padding:24px; }
      .pw-wrap { max-width:420px; }
      .pw-mark { font-family:'Marcellus',serif; font-size:24px; letter-spacing:.30em; }
      .pw-sub { font-size:9px; letter-spacing:.42em; text-transform:uppercase; color:#726a5b; margin-top:6px; }
      h1 { font-family:'Marcellus',serif; font-weight:400; font-size:28px; margin:28px 0 10px; }
      p { color:#4b453b; font-weight:300; }
      form { margin-top:22px; display:flex; gap:10px; justify-content:center; flex-wrap:wrap; }
      input { border:1px solid rgba(26,22,17,.2); background:#fffdf8; padding:13px 15px; font:300 14px 'Jost',sans-serif; border-radius:2px; min-width:220px; }
      button { background:#1a1611; color:#fff; border:none; padding:13px 26px; font:400 12px 'Jost',sans-serif; letter-spacing:.14em; text-transform:uppercase; border-radius:2px; cursor:pointer; }
      .pw-err { color:#a3402f; font-size:13px; margin-top:10px; }
    </style>
  </head>
  <body>
    <div class="pw-wrap">
      <div class="pw-mark">MINIMALIST</div>
      <div class="pw-sub">Jewellery</div>
      <h1>Opening soon</h1>
      <p>Something quietly brilliant is on its way.</p>
      {%- form 'storefront_password' -%}
        {%- if form.errors -%}<div class="pw-err">{{ form.errors.translated_fields.password | capitalize }} {{ form.errors.messages.password }}</div>{%- endif -%}
        <input type="password" name="password" placeholder="Enter password" aria-label="Password">
        <button type="submit">Enter</button>
      {%- endform -%}
    </div>
    {{ content_for_layout }}
  </body>
</html>
