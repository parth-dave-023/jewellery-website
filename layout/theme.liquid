<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#f7f3ec">
    <link rel="canonical" href="{{ canonical_url }}">
    <meta name="description" content="Minimalist Jewellery — everyday fine jewellery. Certified diamonds, responsibly sourced, crafted to be worn for life.">
    <title>{{ page_title | default: shop.name }}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Marcellus&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'%3E%3Crect x='6' y='6' width='12' height='12' fill='none' stroke='%2316181B' stroke-width='1.5' transform='rotate(45 12 12)'/%3E%3C/svg%3E">

    {{ content_for_header }}

    {{ 'mj-app.css' | asset_url | stylesheet_tag }}

    <script>
      window.MJ_ASSETS = {
        "/img/hero.png": {{ 'mj-hero.png' | asset_url | json }},
        "/products/asimi/asimi-1-front.jpg": {{ 'asimi-1-front.jpg' | asset_url | json }},
        "/products/asimi/asimi-2-side.jpg": {{ 'asimi-2-side.jpg' | asset_url | json }},
        "/products/asimi/asimi-3-underside.jpg": {{ 'asimi-3-underside.jpg' | asset_url | json }},
        "/products/asimi/asimi-4-detail.jpg": {{ 'asimi-4-detail.jpg' | asset_url | json }},
        "/products/asimi/asimi-video.mp4": {{ 'asimi-video.mp4' | asset_url | json }}
      };
    </script>
  </head>
  <body>
    <div id="root"></div>
    {{ content_for_layout }}
    <script type="module" src="{{ 'mj-app.js' | asset_url }}"></script>
  </body>
</html>
