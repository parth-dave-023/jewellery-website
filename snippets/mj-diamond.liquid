{%- comment -%}
  Faceted gemstone icon for a diamond cut. Usage:
  {% render 'mj-diamond', shape: 'Pear' %}
  Draws with currentColor so hover/active recolour works.
{%- endcomment -%}
{%- assign s = shape | strip | downcase -%}
<svg class="mj-diamond" width="46" height="46" viewBox="0 0 48 48" fill="none" aria-hidden="true" focusable="false">
  {%- case s -%}
    {%- when 'round' -%}
      <circle cx="24" cy="24" r="18" stroke="currentColor" stroke-width="1.4"/>
      <circle cx="24" cy="24" r="10.5" stroke="currentColor" stroke-width="1"/>
      <path d="M24 6v7.5M42 24h-7.5M24 42v-7.5M6 24h7.5M11.3 11.3l5.3 5.3M36.7 11.3l-5.3 5.3M36.7 36.7l-5.3-5.3M11.3 36.7l5.3-5.3" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
    {%- when 'oval' -%}
      <ellipse cx="24" cy="24" rx="12.5" ry="18" stroke="currentColor" stroke-width="1.4"/>
      <ellipse cx="24" cy="24" rx="7" ry="10.5" stroke="currentColor" stroke-width="1"/>
      <path d="M24 6v7.5M24 42v-7.5M11.5 24h5.5M31 24h5.5" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
    {%- when 'pear' -%}
      <path d="M24 5c6 7 13 12 13 21a13 13 0 0 1-26 0C11 17 18 12 24 5Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
      <path d="M24 15c3 4 7 6 7 11a7 7 0 0 1-14 0c0-5 4-7 7-11Z" stroke="currentColor" stroke-width="1" stroke-linejoin="round"/>
      <path d="M24 5v10M17 26h-6M31 26h6M24 40v-6" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
    {%- when 'marquise' -%}
      <path d="M24 5c8 6 12 13 12 19s-4 13-12 19c-8-6-12-13-12-19s4-13 12-19Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
      <ellipse cx="24" cy="24" rx="6" ry="12" stroke="currentColor" stroke-width="1"/>
      <path d="M24 5v7M24 43v-7M12 24h6M36 24h-6" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
    {%- when 'emerald' -%}
      <path d="M17 6h14l5 5v26l-5 5H17l-5-5V11l5-5Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
      <path d="M18 13h12v22H18zM12 11l6 2M36 11l-6 2M12 37l6-2M36 37l-6-2" stroke="currentColor" stroke-width="1" stroke-linejoin="round"/>
    {%- when 'asscher' -%}
      <path d="M15 6h18l9 9v18l-9 9H15l-9-9V15l9-9Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
      <path d="M17 17h14v14H17zM6 15l11 2M42 15l-11 2M6 33l11-2M42 33l-11-2" stroke="currentColor" stroke-width="1" stroke-linejoin="round"/>
    {%- when 'princess' -%}
      <rect x="7" y="7" width="34" height="34" rx="2" stroke="currentColor" stroke-width="1.4"/>
      <path d="M7 7l17 17 17-17M41 41L24 24 7 41M24 7v34M7 24h34" stroke="currentColor" stroke-width="1"/>
    {%- when 'cushion' -%}
      <rect x="6" y="6" width="36" height="36" rx="12" stroke="currentColor" stroke-width="1.4"/>
      <rect x="15" y="15" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1"/>
      <path d="M9 9l6 6M39 9l-6 6M39 39l-6-6M9 39l6-6" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
    {%- when 'radiant' -%}
      <path d="M14 7h20l7 7v20l-7 7H14l-7-7V14l7-7Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
      <rect x="16" y="16" width="16" height="16" rx="2" stroke="currentColor" stroke-width="1"/>
      <path d="M7 14l9 2M41 14l-9 2M7 34l9-2M41 34l-9-2" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
    {%- else -%}
      <circle cx="24" cy="24" r="18" stroke="currentColor" stroke-width="1.4"/>
      <circle cx="24" cy="24" r="10.5" stroke="currentColor" stroke-width="1"/>
  {%- endcase -%}
</svg>
